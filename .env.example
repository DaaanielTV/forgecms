# Flask Configuration
FLASK_APP=app
FLASK_ENV=development
SECRET_KEY=change-this-to-a-secure-secret-key

# Database Configuration
DB_HOST=localhost
DB_USER=forgecms
DB_PASSWORD=your-secure-password
DB_NAME=forgecms

# Upload Configuration
UPLOAD_FOLDER=static/uploads  # Keep this under static/ so uploads can be served.
MAX_CONTENT_LENGTH=16777216   # Value is in bytes (16MB max file size).
