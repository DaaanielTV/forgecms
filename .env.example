# Flask Configuration
FLASK_APP=app
FLASK_ENV=production
SECRET_KEY=change-this-to-a-secure-secret-key

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=forgecms
DB_PASSWORD=your-secure-password
DB_NAME=forgecms
DB_ROOT_PASSWORD=change-root-password

# Optional full SQLAlchemy DSN override (takes precedence over DB_* values)
# SQLALCHEMY_DATABASE_URI=mysql://forgecms:your-secure-password@localhost:3306/forgecms

# Upload Configuration
UPLOAD_FOLDER=static/uploads
MAX_CONTENT_LENGTH=16777216
